# ============================================================
# CosmoSync — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL — Neon free tier: https://neon.tech
DATABASE_URL=""

# ── Anthropic Claude API ──────────────────────────────────────
# Used by the Astro-Wellness Journal for personalised insights.
# Journal works without this (template fallback), but Claude
# makes it significantly better.
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# ── Razorpay ──────────────────────────────────────────────────
# Indian payment gateway — supports UPI, cards, net banking,
# Google Pay, PhonePe, Paytm and more.
# Sign up at: https://dashboard.razorpay.com
# Use TEST mode keys (rzp_test_...) during development.
#
# Developers → API Keys → Generate Test Key
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Webhook signing secret — set when creating a webhook endpoint
# in Razorpay dashboard: Developers → Webhooks → Add Webhook
RAZORPAY_WEBHOOK_SECRET=""

# Public key exposed to browser (same as RAZORPAY_KEY_ID)
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# ── App Base URL ──────────────────────────────────────────────
# Local dev: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
